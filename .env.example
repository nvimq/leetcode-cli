# LeetCode Credentials
# Get these from your browser DevTools -> Application/Storage -> Cookies for
# https://leetcode.com (or https://leetcode.cn).
#
# LEETCODE_SESSION  - long-lived session cookie, REQUIRED
# LEETCODE_CSRFTOKEN - CSRF token cookie, REQUIRED for leetcode.com submits
# LEETCODE_CFCLEARANCE - Cloudflare clearance cookie, REQUIRED for leetcode.com
#                       (expires in hours, refresh when SESSION_EXPIRED is returned)
#
# LEETCODE_BASE_URL - optional, default https://leetcode.com (use https://leetcode.cn for CN)

LEETCODE_SESSION=
LEETCODE_CSRFTOKEN=
LEETCODE_CFCLEARANCE=
LEETCODE_BASE_URL=https://leetcode.com